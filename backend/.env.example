# Server Port
PORT=3001

# OpenRouter AI Access
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Clerk Authentication (Get from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Firebase Admin SDK Credentials (Get from Firebase Console -> Project Settings -> Service Accounts)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# Note: Escape newlines in private key if providing as a string, e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkq..."
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS Frontend Allowed Origins (Comma-separated for multiple origins, e.g., http://localhost:3000,https://trinetra.pages.dev)
FRONTEND_URL=http://localhost:3000,http://localhost:5173
